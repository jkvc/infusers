# Copy to .env and fill in (never commit .env).
# Proxy tokens: https://modal.com/settings/proxy-auth-tokens  (wk- / ws-, not ak- API tokens)

# --- Primary Modal app (lunas-courageous-adventure) ---
# One deploy = two URLs. Routes share them — pick recipe via "path" in the POST body.
# Labels: web = APP_NAME, stream = APP_NAME + "-stream" (see modal_app/*.py).
MODAL_WEB_URL=https://<workspace>--lunas-courageous-adventure.modal.run
MODAL_STREAM_URL=https://<workspace>--lunas-courageous-adventure-stream.modal.run

MODAL_KEY=wk-REPLACE_ME
MODAL_SECRET=ws-REPLACE_ME

# --- Optional: second deploy (dummy_image.py — CPU e2e only) ---
# MODAL_DUMMY_WEB_URL=https://<workspace>--infusers-dummy-image.modal.run
# MODAL_DUMMY_STREAM_URL=https://<workspace>--infusers-dummy-image-stream.modal.run
