# Local reference only — copy to .env (gitignored).
# Remote fal workers use `fal secret set`, not this file.

# fal API key (key_id:key_secret) — for calling private deployments locally
# https://fal.ai/dashboard/keys
FAL_KEY=

# Hugging Face read token — optional if you use `uv run hf auth login`
# Required for fal workers: `uv run fal secret set HF_TOKEN`
# https://huggingface.co/settings/tokens
HF_TOKEN=
